rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Qualquer pessoa pode ver as imagens (necessário para o catálogo)
      allow read: if true;
      
      // Apenas utilizadores com login feito podem enviar/apagar imagens
      allow write: if request.auth != null;
    }
  }
}